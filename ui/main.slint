import { Button, CheckBox, ComboBox, GroupBox, LineEdit, Switch, VerticalBox, HorizontalBox } from "std-widgets.slint";

component PremiumButton inherits Rectangle {
    in property <string> text;
    in property <bool> is_primary: true;
    callback clicked();

    height: 48px;
    border-radius: 8px;
    background: touch.pressed ? (is_primary ? #2563EB : #334155) : (touch.has-hover ? (is_primary ? #3B82F6 : #475569) : (is_primary ? #1D4ED8 : #1E293B));
    
    animate background { duration: 150ms; }
    
    drop-shadow-color: #00000040;
    drop-shadow-blur: 8px;
    drop-shadow-offset-y: 4px;

    Text {
        text: root.text;
        color: white;
        font-size: 16px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => { root.clicked() }
    }
}

component PremiumSwitch inherits Rectangle {
    in-out property <bool> checked: false;
    callback toggled();

    width: 44px;
    height: 24px;
    border-radius: 12px;
    background: root.checked ? #10B981 : #475569;
    animate background { duration: 200ms; }

    Rectangle {
        width: 20px;
        height: 20px;
        border-radius: 10px;
        background: white;
        x: root.checked ? root.width - self.width - 2px : 2px;
        y: 2px;
        animate x { duration: 200ms; easing: ease-in-out; }
        
        drop-shadow-color: #00000040;
        drop-shadow-blur: 4px;
        drop-shadow-offset-y: 2px;
    }

    touch := TouchArea {
        clicked => { 
            root.checked = !root.checked;
            root.toggled();
        }
    }
}

export component MainWindow inherits Window {
    title: "2con Client";
    width: 340px;
    height: 520px;
    background: #0F172A; // Deep corporate slate
    
    // Callbacks
    callback toggle_connect();
    callback set_autopilot(bool);
    callback set_scan_mode(bool);
    
    // Properties
    in-out property <bool> connected: false;
    in-out property <string> status_text: "Disconnected";
    in-out property <string> current_ip: "N/A";
    in-out property <string> latency: "-";
    in-out property <bool> is_scanning: false;
    in-out property <bool> autopilot_enabled: false;
    
    VerticalBox {
        padding: 24px;
        spacing: 24px;
        
        // Header
        HorizontalBox {
            alignment: center;
            spacing: 8px;
            
            Rectangle {
                width: 32px;
                height: 32px;
                border-radius: 8px;
                background: #3B82F6;
                Text {
                    text: "2";
                    color: white;
                    font-size: 20px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
            Text {
                text: "2con Client";
                font-size: 22px;
                font-weight: 700;
                color: #F8FAFC;
                vertical-alignment: center;
            }
        }
        
        // Status Card
        Rectangle {
            height: 140px;
            background: connected ? #064E3B : #1E293B; // Dark emerald or slate
            border-radius: 16px;
            border-width: 1px;
            border-color: connected ? #059669 : #334155;
            animate background, border-color { duration: 300ms; }
            
            drop-shadow-color: connected ? #10B98120 : #00000040;
            drop-shadow-blur: 16px;
            drop-shadow-offset-y: 8px;
            
            VerticalBox {
                alignment: center;
                spacing: 8px;
                
                Text {
                    text: root.status_text;
                    color: connected ? #34D399 : #94A3B8;
                    font-size: 20px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    animate color { duration: 300ms; }
                }
                
                HorizontalBox {
                    alignment: center;
                    spacing: 16px;
                    
                    VerticalBox {
                        Text { text: "IP ADDRESS"; font-size: 10px; color: #64748B; font-weight: 600; horizontal-alignment: center; }
                        Text { text: root.current_ip; font-size: 14px; color: #F8FAFC; font-weight: 500; horizontal-alignment: center; }
                    }
                    
                    Rectangle { width: 1px; height: 30px; background: #334155; }
                    
                    VerticalBox {
                        Text { text: "LATENCY"; font-size: 10px; color: #64748B; font-weight: 600; horizontal-alignment: center; }
                        Text { text: root.latency; font-size: 14px; color: #F8FAFC; font-weight: 500; horizontal-alignment: center; }
                    }
                }
            }
        }
        
        PremiumButton {
            text: connected ? "Disconnect" : "Connect";
            is_primary: !connected;
            clicked => { root.toggle_connect() }
        }
        
        // Settings panel
        Rectangle {
            background: #1E293B;
            border-radius: 12px;
            
            VerticalBox {
                padding: 16px;
                spacing: 16px;
                
                HorizontalBox {
                    Text {
                        text: "Autopilot Mode";
                        color: #E2E8F0;
                        font-size: 14px;
                        font-weight: 500;
                        vertical-alignment: center;
                    }
                    Rectangle { horizontal-stretch: 1; }
                    PremiumSwitch {
                        checked: root.autopilot_enabled;
                        toggled => {
                            root.autopilot_enabled = self.checked;
                            root.set_autopilot(self.checked);
                        }
                    }
                }
                
                Rectangle { height: 1px; background: #334155; }
                
                HorizontalBox {
                    Text {
                        text: "Cloudflare Auto-Scan";
                        color: #E2E8F0;
                        font-size: 14px;
                        font-weight: 500;
                        vertical-alignment: center;
                    }
                    Rectangle { horizontal-stretch: 1; }
                    PremiumSwitch {
                        checked: root.is_scanning;
                        toggled => {
                            root.is_scanning = self.checked;
                            root.set_scan_mode(self.checked);
                        }
                    }
                }
            }
        }
        
        Rectangle {
            vertical-stretch: 1;
        }
        
        Text {
            text: "Enterprise secure routing enabled";
            color: #475569;
            font-size: 11px;
            horizontal-alignment: center;
        }
    }
}
