export global Theme {
    // Background and Surfaces
    out property <color> app-bg: #030005;
    out property <color> surface: #0A0010;
    out property <color> surface-raised: #120024;
    out property <color> surface-hover: #1a0033;
    out property <color> surface-pressed: #120024;
    
    // Borders
    out property <color> border: #ffffff11;
    out property <color> border-hover: #bf00ff55;
    
    // Accent Colors
    out property <color> primary: #bf00ff;
    out property <color> primary-hover: #d100ff;
    out property <color> primary-pressed: #a300d9;
    
    out property <color> secondary: #00e5ff;
    out property <color> secondary-hover: #33eaff;
    
    // Semantic Colors
    out property <color> danger: #DC2626;
    out property <color> danger-hover: #EF4444;
    out property <color> danger-pressed: #B91C1C;
    out property <color> danger-bg: #DC262622;
    
    out property <color> success: #10B981;
    out property <color> success-bg: #10B98122;
    
    out property <color> warning: #F59E0B;
    
    out property <color> disabled: #333333;
    
    // Text Hierarchy
    out property <color> text-primary: #ffffff;
    out property <color> text-secondary: #aaaaaa;
    out property <color> text-muted: #777777;
    out property <color> text-disabled: #555555;
    out property <color> text-accent: #00e5ff;
    
    // Focus & States
    out property <color> focus-ring: #00e5ff88;
    out property <length> focus-ring-width: 2px;
    // Type Scale & Fonts
    out property <string> font-primary: "Inter, system-ui, sans-serif";
    out property <string> font-mono: "JetBrains Mono, Consolas, monospace";
    out property <int> font-weight-regular: 400;
    out property <int> font-weight-medium: 500;
    out property <int> font-weight-bold: 600;
    out property <length> font-title: 24px;
    out property <length> font-header: 20px;
    out property <length> font-body-large: 16px;
    out property <length> font-body: 14px;
    out property <length> font-sub: 12px;
    out property <length> font-caption: 10px;
    
    // Radii
    out property <length> radius-small: 4px;
    out property <length> radius-medium: 8px;
    out property <length> radius-large: 12px;
    out property <length> radius-pill: 9999px;

    // Icon Sizes
    out property <length> icon-small: 16px;
    out property <length> icon-medium: 20px;
    out property <length> icon-large: 32px;
    out property <length> icon-xlarge: 52px;
}
