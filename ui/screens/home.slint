export component HomeScreen inherits Rectangle {
    in property <string> connection-status: "Disconnected";
    in property <string> active-profile: "No Profile Selected";
    in property <string> download-speed: "0 KB/s";
    in property <string> upload-speed: "0 KB/s";
    in property <string> total-download: "0 MB";
    in property <string> total-upload: "0 MB";
    in property <bool> is-connected: false;
    in property <bool> is-connecting: false;
    
    callback toggle-connection();

    background: #171821;

    VerticalLayout {
        padding: 24px;
        spacing: 24px;

        // Top Info Bar
        Rectangle {
            background: #21222d;
            border-radius: 12px;
            height: 60px;
            
            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                alignment: space-between;
                
                // Active Profile Info
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    
                    Text {
                        text: "Profile:";
                        color: #a0aec0;
                        font-size: 14px;
                        vertical-alignment: center;
                    }
                    Text {
                        text: active-profile;
                        color: #ffffff;
                        font-size: 14px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }

                // Core Stats / Delay (Mock or actual)
                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;
                    
                    Text {
                        text: is-connected ? "System Proxy Active" : "Proxy Inactive";
                        color: is-connected ? #48bb78 : #a0aec0;
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Circular Connect Button Section
        VerticalLayout {
            alignment: center;
            spacing: 16px;
            
            Rectangle {
                width: 180px;
                height: 180px;
                background: is-connected ? #0f3d30 : (is-connecting ? #3d300f : #2c1a24);
                border-radius: 90px;
                border-color: is-connected ? #48bb78 : (is-connecting ? #ecc94b : #e53e3e);
                border-width: 4px;
                
                // Connect/Disconnect inner button action
                TouchArea {
                    clicked => { root.toggle-connection(); }
                    
                    VerticalLayout {
                        alignment: center;
                        spacing: 8px;
                        
                        // Icon Placeholder (Visual status)
                        Rectangle {
                            width: 40px;
                            height: 40px;
                            border-radius: 20px;
                            background: is-connected ? #48bb78 : (is-connecting ? #ecc94b : #e53e3e);
                            
                            Text {
                                text: is-connected ? "✔" : "⚡";
                                color: #171821;
                                font-size: 18px;
                                font-weight: 800;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                            }
                        }

                        Text {
                            text: is-connected ? "Connected" : (is-connecting ? "Connecting..." : "Tap to Connect");
                            color: #ffffff;
                            font-size: 16px;
                            font-weight: 700;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: is-connected ? "Click to Disconnect" : "Core Stopped";
                            color: #a0aec0;
                            font-size: 11px;
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }

        // Traffic Stats Panel
        HorizontalLayout {
            spacing: 16px;
            height: 100px;
            
            // Downlink Card
            Rectangle {
                background: #21222d;
                border-radius: 12px;
                padding: 12px;
                
                VerticalLayout {
                    alignment: space-around;
                    
                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: "↓"; color: #4299e1; font-size: 18px; font-weight: 900; }
                        Text { text: "Download Speed"; color: #a0aec0; font-size: 12px; }
                    }
                    Text {
                        text: download-speed;
                        color: #ffffff;
                        font-size: 20px;
                        font-weight: 700;
                    }
                    Text {
                        text: "Total: " + total-download;
                        color: #718096;
                        font-size: 11px;
                    }
                }
            }

            // Uplink Card
            Rectangle {
                background: #21222d;
                border-radius: 12px;
                padding: 12px;
                
                VerticalLayout {
                    alignment: space-around;
                    
                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: "↑"; color: #ecc94b; font-size: 18px; font-weight: 900; }
                        Text { text: "Upload Speed"; color: #a0aec0; font-size: 12px; }
                    }
                    Text {
                        text: upload-speed;
                        color: #ffffff;
                        font-size: 20px;
                        font-weight: 700;
                    }
                    Text {
                        text: "Total: " + total-upload;
                        color: #718096;
                        font-size: 11px;
                    }
                }
            }
        }

        // Bottom space filler
        Rectangle {
            background: transparent;
        }
    }
}
