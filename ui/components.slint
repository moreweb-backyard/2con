import { Theme } from "theme.slint";
import { ComboBox, LineEdit } from "std-widgets.slint";

export component PremiumButton inherits Rectangle {
    in property <string> text;
    in property <bool> is_primary: true;
    in property <bool> is_danger: false;
    in property <bool> has_icon: false;
    in property <image> icon;
    in property <bool> enabled: true;
    callback clicked();

    height: 36px;
    border-radius: Theme.radius-medium;
    forward-focus: focus_scope;
    
    // States: disabled, pressed, hover, default
    background: !root.enabled ? Theme.disabled : (
        touch.pressed ? (is_danger ? Theme.danger-pressed : (is_primary ? Theme.primary-pressed : Theme.surface-pressed)) : (
            touch.has-hover ? (is_danger ? Theme.danger-hover : (is_primary ? Theme.primary-hover : Theme.surface-hover)) : (
                is_danger ? Theme.danger : (is_primary ? Theme.primary : Theme.surface-raised)
            )
        )
    );
    
    border-width: focus_scope.has-focus ? Theme.focus-ring-width : 0px;
    border-color: Theme.focus-ring;
    
    drop-shadow-color: !root.enabled ? transparent : (is_primary ? #bf00ff22 : transparent);
    drop-shadow-blur: touch.has-hover && root.enabled ? 4px : 0px;
    
    animate background, drop-shadow-blur, border-width { duration: 150ms; }
    
    HorizontalLayout {
        alignment: center;
        spacing: 8px;
        if root.has_icon: VerticalLayout {
            alignment: center;
            Image {
                source: root.icon;
                width: Theme.icon-small;
                height: Theme.icon-small;
                colorize: !root.enabled ? Theme.text-disabled : Theme.text-primary;
            }
        }
        Text {
            text: root.text;
            color: !root.enabled ? Theme.text-disabled : Theme.text-primary;
            font-size: Theme.font-body;
            font-weight: 600;
            vertical-alignment: center;
        }
    }

    focus_scope := FocusScope {
        key-pressed(e) => {
            if (e.text == " " || e.text == "\n") {
                if (root.enabled) { root.clicked(); }
                return accept;
            }
            return reject;
        }
    }

    touch := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { 
            if (root.enabled) {
                root.clicked();
            }
        }
    }
}

export component PremiumSwitch inherits Rectangle {
    in-out property <bool> checked: false;
    in property <bool> enabled: true;
    callback toggled();

    width: 44px;
    height: 24px;
    border-radius: 12px;
    forward-focus: focus_scope;
    background: !root.enabled ? Theme.disabled : (root.checked ? Theme.secondary : Theme.surface-raised);
    border-width: focus_scope.has-focus ? Theme.focus-ring-width : 0px;
    border-color: Theme.focus-ring;
    animate background, border-width { duration: 200ms; }

    Rectangle {
        width: 20px;
        height: 20px;
        border-radius: 10px;
        background: !root.enabled ? Theme.text-disabled : Theme.text-primary;
        x: root.checked ? root.width - self.width - 2px : 2px;
        y: 2px;
        animate x { duration: 200ms; easing: ease-in-out; }
    }

    focus_scope := FocusScope {
        key-pressed(e) => {
            if (e.text == " " || e.text == "\n") {
                if (root.enabled) { 
                    root.checked = !root.checked;
                    root.toggled(); 
                }
                return accept;
            }
            return reject;
        }
    }

    touch := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { 
            if (root.enabled) {
                root.checked = !root.checked;
                root.toggled();
            }
        }
    }
}

export component IconButton inherits Rectangle {
    in property <image> icon;
    in property <string> tooltip_text;
    in property <bool> is_primary: false;
    in property <bool> is_danger: false;
    in property <bool> enabled: true;
    callback clicked();

    width: 32px;
    height: 32px;
    border-radius: Theme.radius-small;
    forward-focus: focus_scope;
    
    background: !root.enabled ? transparent : (
        touch.pressed ? (is_danger ? Theme.danger-pressed : (is_primary ? Theme.primary-pressed : Theme.surface-pressed)) : (
            touch.has-hover ? (is_danger ? Theme.danger-bg : (is_primary ? #bf00ff22 : Theme.surface-hover)) : transparent
        )
    );
    
    border-width: focus_scope.has-focus ? Theme.focus-ring-width : (touch.has-hover && root.enabled ? 1px : 0px);
    border-color: focus_scope.has-focus ? Theme.focus-ring : (is_danger ? Theme.danger : (is_primary ? Theme.primary : Theme.border));
    
    animate background, border-width { duration: 150ms; }
    
    Image {
        source: root.icon;
        colorize: !root.enabled ? Theme.text-disabled : (
            is_danger ? Theme.danger : (is_primary ? Theme.primary : (touch.has-hover ? Theme.text-primary : Theme.text-secondary))
        );
        width: Theme.icon-small;
        height: Theme.icon-small;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        animate colorize { duration: 150ms; }
    }

    focus_scope := FocusScope {
        key-pressed(e) => {
            if (e.text == " " || e.text == "\n") {
                if (root.enabled) { root.clicked(); }
                return accept;
            }
            return reject;
        }
    }

    touch := TouchArea {
        width: 100%; height: 100%;
        clicked => { 
            if (root.enabled) { root.clicked(); }
        }
    }
    
    // Tooltip
    if tooltip_text != "": Rectangle {
        y: -28px;
        x: (parent.width - self.width) / 2;
        width: tooltip_text_elem.width + 16px;
        height: 24px;
        border-radius: Theme.radius-small;
        background: Theme.app-bg;
        border-width: 1px;
        border-color: is_danger ? Theme.danger : (is_primary ? Theme.primary : Theme.border);
        opacity: touch.has-hover && root.enabled ? 1 : 0;
        animate opacity { duration: 200ms; }
        
        tooltip_text_elem := Text {
            text: root.tooltip_text;
            color: Theme.text-primary;
            font-size: Theme.font-caption;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
            x: 8px;
        }
    }
}

export component SidebarItem inherits Rectangle {
    in property <string> text;
    in property <bool> is_active: false;
    callback clicked();

    height: 36px;
    forward-focus: focus_scope;
    
    background: is_active ? Theme.surface-raised : (touch.has-hover ? Theme.surface-hover : transparent);
    
    border-width: 0px;
    
    animate background { duration: 150ms; }

    HorizontalLayout {
        padding-left: 12px;
        Text {
            text: root.text;
            color: is_active ? Theme.text-accent : (touch.has-hover ? Theme.text-primary : Theme.text-secondary);
            font-size: Theme.font-body;
            font-weight: is_active ? 700 : 500;
            vertical-alignment: center;
            height: 100%;
            animate color { duration: 150ms; }
        }
    }

    focus_scope := FocusScope {
        key-pressed(e) => {
            if (e.text == " " || e.text == "\n") {
                root.clicked();
                return accept;
            }
            return reject;
        }
    }

    touch := TouchArea {
        width: 100%; height: 100%;
        clicked => { root.clicked() }
    }
}

export component GlassActionCard inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <image> icon;
    callback clicked();

    height: 70px;
    border-radius: Theme.radius-large;
    background: touch.pressed ? Theme.surface-pressed : (touch.has-hover ? Theme.surface-hover : Theme.surface);
    border-width: focus_scope.has-focus ? Theme.focus-ring-width : 1px;
    border-color: focus_scope.has-focus ? Theme.focus-ring : (touch.has-hover ? Theme.border-hover : Theme.border);
    drop-shadow-blur: touch.has-hover ? 4px : 2px;
    drop-shadow-color: touch.has-hover ? #bf00ff11 : #00000033;

    animate background, border-color, drop-shadow-color { duration: 200ms; }

    HorizontalLayout {
        padding: 12px;
        spacing: 16px;
        alignment: start;

        Rectangle {
            width: 44px; height: 44px; border-radius: 22px;
            background: #bf00ff22;
            HorizontalLayout { alignment: center; VerticalLayout { alignment: center; Image { source: root.icon; colorize: Theme.secondary; width: Theme.icon-medium; height: Theme.icon-medium; } } }
        }

        VerticalLayout {
            alignment: center;
            spacing: 2px;
            Text { text: root.title; color: Theme.text-primary; font-size: Theme.font-body; font-weight: 700; }
            Text { text: root.subtitle; color: Theme.text-muted; font-size: Theme.font-sub; }
        }
    }

    touch := TouchArea { clicked => { root.clicked() } }
    
    forward-focus: focus_scope;
    focus_scope := FocusScope {
        key-pressed(e) => {
            if (e.text == " " || e.text == "\n") {
                root.clicked();
                return accept;
            }
            return reject;
        }
    }
}

export component PremiumScrollView inherits Rectangle {
    in property <length> viewport_height;
    out property <length> viewport_y: flick.viewport-y;
    
    clip: true;
    
    flick := Flickable {
        width: parent.width;
        height: parent.height;
        viewport-height: root.viewport_height;
        @children
    }
    
    if (flick.viewport-height > flick.height): Rectangle {
        width: 4px;
        height: max(20px, flick.height * (flick.height / flick.viewport-height));
        x: parent.width - 6px;
        y: -flick.viewport-y * (flick.height / flick.viewport-height);
        background: #bb86fc66;
        border-radius: 2px;
    }
}

export component AppSectionCard inherits Rectangle {
    in property <string> title;
    in property <string> description;
    
    background: transparent;
    border-width: 0px;
    
    VerticalLayout {
        padding-top: 16px;
        padding-bottom: 16px;
        spacing: 12px;
        
        VerticalLayout {
            spacing: 4px;
            if title != "": Text { text: root.title; color: Theme.text-primary; font-size: Theme.font-header; font-weight: 700; }
            if description != "": Text { text: root.description; color: Theme.text-muted; font-size: Theme.font-sub; wrap: word-wrap; }
        }
        
        Rectangle { height: 1px; background: Theme.surface-raised; }
        
        VerticalLayout {
            spacing: 12px;
            @children
        }
    }
}

export component AppTextField inherits Rectangle {
    in-out property <string> text;
    in property <string> placeholder_text;
    in property <string> label;
    in property <string> helper_text;
    in property <bool> is_error: false;
    
    height: layout.preferred-height;
    
    layout := VerticalLayout {
        spacing: 6px;
        if label != "": Text { text: root.label; color: Theme.text-primary; font-size: Theme.font-body; }
        
        Rectangle {
            height: 36px;
            border-radius: Theme.radius-medium;
            background: Theme.surface-raised;
            border-width: input.has-focus ? Theme.focus-ring-width : 1px;
            border-color: input.has-focus ? Theme.focus-ring : (root.is_error ? Theme.danger : Theme.border);
            animate border-width, border-color { duration: 150ms; }
            
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                input := TextInput {
                    text <=> root.text;
                    color: Theme.text-primary;
                    font-size: Theme.font-body;
                    vertical-alignment: center;
                    single-line: true;
                }
            }
            if root.text == "" && root.placeholder_text != "": Text {
                text: root.placeholder_text;
                color: Theme.text-disabled;
                font-size: Theme.font-body;
                vertical-alignment: center;
                x: 12px;
                y: (parent.height - self.height) / 2;
            }
        }
        
        if helper_text != "": Text { text: root.helper_text; color: is_error ? Theme.danger : Theme.text-muted; font-size: Theme.font-sub; }
    }
}

export component StatusBadge inherits Rectangle {
    in property <string> text;
    in property <bool> is_active: false;
    
    width: 50px;
    height: 20px;
    border-radius: 10px;
    background: is_active ? Theme.success-bg : Theme.surface-hover;
    border-width: 1px;
    border-color: is_active ? Theme.success : Theme.border;
    
    Text { 
        text: root.text; 
        color: is_active ? Theme.success : Theme.text-secondary; 
        font-size: Theme.font-sub; 
        horizontal-alignment: center; 
        vertical-alignment: center; 
        font-weight: 500; 
    }
}

export component EmptyState inherits VerticalLayout {
    in property <string> title;
    in property <string> subtitle;
    in property <image> icon;
    
    alignment: center;
    spacing: 16px;
    padding: 40px;
    
    Rectangle {
        width: 64px; height: 64px; border-radius: 32px;
        background: Theme.surface-raised;
        HorizontalLayout { alignment: center; VerticalLayout { alignment: center; Image { source: root.icon; colorize: Theme.text-muted; width: Theme.icon-large; height: Theme.icon-large; } } }
    }
    
    VerticalLayout {
        spacing: 8px;
        alignment: center;
        Text { text: root.title; color: Theme.text-primary; font-size: Theme.font-header; font-weight: 700; horizontal-alignment: center; }
        Text { text: root.subtitle; color: Theme.text-muted; font-size: Theme.font-body; horizontal-alignment: center; wrap: word-wrap; }
    }
    
    @children
}

export component LoadingIndicator inherits Rectangle {
    width: 24px;
    height: 24px;
    
    Path {
        width: 100%; height: 100%;
        stroke: Theme.secondary;
        stroke-width: 2px;
        commands: "M 12 2 A 10 10 0 0 1 22 12";
        // To make it spin around center 12, 12
        transform-rotation: animation-tick() / 1s * 360deg;
    }
}

export component ModalShell inherits Rectangle {
    in property <string> title;
    in property <bool> is_open: false;
    callback close_clicked();
    
    opacity: root.is_open ? 1 : 0;
    visible: root.opacity > 0;
    animate opacity { duration: 200ms; }
    
    // Backdrop
    TouchArea {
        width: 100%; height: 100%;
        Rectangle { width: 100%; height: 100%; background: #000000aa; }
        clicked => { root.close_clicked() }
    }
    
    // Dialog Box
    Rectangle {
        width: min(parent.width - 40px, 400px);
        height: layout.preferred-height;
        x: (parent.width - self.width) / 2;
        y: root.is_open ? (parent.height - self.height) / 2 : (parent.height - self.height) / 2 + 20px;
        background: Theme.app-bg;
        border-radius: Theme.radius-large;
        border-width: 1px;
        border-color: Theme.border;
        drop-shadow-blur: 20px;
        drop-shadow-color: #000000cc;
        animate y { duration: 200ms; easing: ease-out; }
        
        layout := VerticalLayout {
            padding: 24px;
            spacing: 20px;
            
            HorizontalLayout {
                alignment: space-between;
                Text { text: root.title; color: Theme.text-primary; font-size: Theme.font-header; font-weight: 700; vertical-alignment: center; }
                Rectangle {
                    width: 24px; height: 24px; border-radius: 12px;
                    background: close_touch.has-hover ? Theme.surface-hover : transparent;
                    animate background { duration: 150ms; }
                    HorizontalLayout { alignment: center; VerticalLayout { alignment: center; Text { text: "×"; color: Theme.text-secondary; font-size: Theme.font-header; font-weight: 300; } } }
                    close_touch := TouchArea { clicked => { root.close_clicked() } }
                }
            }
            
            @children
        }
    }
}

export component AppComboBox inherits Rectangle {
    in property <[string]> model;
    in-out property <string> current_value;
    callback selected();
    
    ComboBox {
        model: root.model;
        current-value <=> root.current_value;
        selected => { root.selected() }
    }
}

export component ErrorBanner inherits Rectangle {
    in property <string> message;
    in property <string> level; // "error", "warning", "info"
    callback dismiss();

    height: layout.preferred-height;
    border-radius: Theme.radius-medium;
    background: level == "error" ? Theme.danger-bg : (level == "warning" ? #f59e0b22 : #00e5ff22);
    border-width: 1px;
    border-color: level == "error" ? Theme.danger : (level == "warning" ? Theme.warning : Theme.secondary);
    
    layout := HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 8px;
        padding-bottom: 8px;
        spacing: 12px;
        alignment: space-between;
        
        Text {
            text: root.message;
            color: Theme.text-primary;
            font-size: Theme.font-body;
            vertical-alignment: center;
            horizontal-stretch: 1;
            wrap: word-wrap;
        }
        
        // Close / Dismiss button
        Rectangle {
            width: 20px;
            height: 20px;
            border-radius: 10px;
            background: touch.has-hover ? Theme.surface-hover : transparent;
            
            Text {
                text: "×";
                color: Theme.text-secondary;
                font-size: 16px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            
            touch := TouchArea {
                clicked => { root.dismiss(); }
            }
        }
    }
}