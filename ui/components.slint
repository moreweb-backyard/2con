import { Theme } from "theme.slint";
import { ComboBox, LineEdit } from "std-widgets.slint";

export component PremiumButton inherits Rectangle {
    in property <string> text;
    in property <bool> is_primary: true;
    in property <bool> is_danger: false;
    in property <bool> has_icon: false;
    in property <image> icon;
    in property <bool> enabled: true;
    callback clicked();

    height: 36px;
    border-radius: Theme.radius-medium;
    
    // States: disabled, pressed, hover, default
    background: !root.enabled ? Theme.disabled : (
        touch.pressed ? (is_danger ? Theme.danger-pressed : (is_primary ? Theme.primary-pressed : Theme.surface-pressed)) : (
            touch.has-hover ? (is_danger ? Theme.danger-hover : (is_primary ? Theme.primary-hover : Theme.surface-hover)) : (
                is_danger ? Theme.danger : (is_primary ? Theme.primary : Theme.surface-raised)
            )
        )
    );
    
    border-width: false ? Theme.focus-ring-width : 0px;
    border-color: Theme.focus-ring;
    
    drop-shadow-color: !root.enabled ? transparent : (is_primary ? #bf00ff44 : transparent);
    drop-shadow-blur: touch.has-hover && root.enabled ? 10px : 0px;
    
    animate background, drop-shadow-blur, border-width { duration: 150ms; }
    
    HorizontalLayout {
        alignment: center;
        spacing: 8px;
        if root.has_icon: Image {
            source: root.icon;
            width: 16px;
            height: 16px;
            colorize: !root.enabled ? Theme.text-disabled : Theme.text-primary;
            y: (parent.height - self.height) / 2;
        }
        Text {
            text: root.text;
            color: !root.enabled ? Theme.text-disabled : Theme.text-primary;
            font-size: Theme.font-body;
            font-weight: 600;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { 
            if (root.enabled) {
                root.clicked();
            }
        }
    }
}

export component PremiumSwitch inherits Rectangle {
    in-out property <bool> checked: false;
    in property <bool> enabled: true;
    callback toggled();

    width: 44px;
    height: 24px;
    border-radius: 12px;
    background: !root.enabled ? Theme.disabled : (root.checked ? Theme.secondary : Theme.surface-raised);
    border-width: false ? Theme.focus-ring-width : 0px;
    border-color: Theme.focus-ring;
    animate background, border-width { duration: 200ms; }

    Rectangle {
        width: 20px;
        height: 20px;
        border-radius: 10px;
        background: !root.enabled ? Theme.text-disabled : Theme.text-primary;
        x: root.checked ? root.width - self.width - 2px : 2px;
        y: 2px;
        animate x { duration: 200ms; easing: ease-in-out; }
    }

    touch := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { 
            if (root.enabled) {
                root.checked = !root.checked;
                root.toggled();
            }
        }
    }
}

export component IconButton inherits Rectangle {
    in property <image> icon;
    in property <string> tooltip_text;
    in property <bool> is_primary: false;
    in property <bool> is_danger: false;
    in property <bool> enabled: true;
    callback clicked();

    width: 32px;
    height: 32px;
    border-radius: Theme.radius-small;
    
    background: !root.enabled ? transparent : (
        touch.pressed ? (is_danger ? Theme.danger-pressed : (is_primary ? Theme.primary-pressed : Theme.surface-pressed)) : (
            touch.has-hover ? (is_danger ? Theme.danger-bg : (is_primary ? #bf00ff22 : Theme.surface-hover)) : transparent
        )
    );
    
    border-width: false ? Theme.focus-ring-width : (touch.has-hover && root.enabled ? 1px : 0px);
    border-color: false ? Theme.focus-ring : (is_danger ? Theme.danger : (is_primary ? Theme.primary : Theme.border));
    
    animate background, border-width { duration: 150ms; }
    
    Image {
        source: root.icon;
        colorize: !root.enabled ? Theme.text-disabled : (
            is_danger ? Theme.danger : (is_primary ? Theme.primary : (touch.has-hover ? Theme.text-primary : Theme.text-secondary))
        );
        width: 16px;
        height: 16px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        animate colorize { duration: 150ms; }
    }

    touch := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { 
            if (root.enabled) {
                root.clicked();
            }
        }
    }
    
    // Tooltip
    if tooltip_text != "": Rectangle {
        y: -28px;
        x: (parent.width - self.width) / 2;
        width: tooltip_text_elem.width + 16px;
        height: 24px;
        border-radius: Theme.radius-small;
        background: Theme.app-bg;
        border-width: 1px;
        border-color: is_danger ? Theme.danger : (is_primary ? Theme.primary : Theme.border);
        opacity: touch.has-hover && root.enabled ? 1 : 0;
        animate opacity { duration: 200ms; }
        
        tooltip_text_elem := Text {
            text: root.tooltip_text;
            color: Theme.text-primary;
            font-size: Theme.font-caption;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
            x: 8px;
        }
    }
}

export component SidebarItem inherits Rectangle {
    in property <string> text;
    in property <bool> is_active: false;
    callback clicked();

    height: 36px;
    border-radius: Theme.radius-medium;
    background: is_active ? #bf00ff33 : (touch.has-hover ? Theme.surface-hover : transparent);
    
    border-width: false ? Theme.focus-ring-width : 0px;
    border-color: Theme.focus-ring;
    
    animate background { duration: 150ms; }

    Rectangle {
        width: 3px;
        height: 20px;
        border-radius: 1.5px;
        background: is_active ? Theme.secondary : transparent;
        x: 0;
        y: (parent.height - self.height) / 2;
        animate background { duration: 150ms; }
    }

    Text {
        text: root.text;
        color: is_active ? Theme.text-accent : (touch.has-hover ? Theme.text-primary : Theme.text-secondary);
        font-size: Theme.font-body;
        font-weight: is_active ? 700 : 500;
        x: 16px;
        vertical-alignment: center;
        height: 100%;
        animate color { duration: 150ms; }
    }

    touch := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.clicked() }
    }
}

export component GlassActionCard inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <image> icon;
    callback clicked();

    height: 70px;
    border-radius: Theme.radius-large;
    background: touch.pressed ? Theme.surface-pressed : (touch.has-hover ? Theme.surface-hover : Theme.surface);
    border-width: false ? Theme.focus-ring-width : 1px;
    border-color: false ? Theme.focus-ring : (touch.has-hover ? Theme.border-hover : Theme.border);
    drop-shadow-blur: touch.has-hover ? 10px : 5px;
    drop-shadow-color: touch.has-hover ? #bf00ff22 : #00000055;

    animate background, border-color, drop-shadow-color { duration: 200ms; }

    HorizontalLayout {
        padding: 12px;
        spacing: 16px;
        alignment: start;

        Rectangle {
            width: 44px; height: 44px; border-radius: 22px;
            background: #bf00ff22;
            Image { source: root.icon; colorize: Theme.secondary; width: 20px; height: 20px; x: 12px; y: 12px; }
        }

        VerticalLayout {
            alignment: center;
            spacing: 2px;
            Text { text: root.title; color: Theme.text-primary; font-size: Theme.font-body; font-weight: 700; }
            Text { text: root.subtitle; color: Theme.text-muted; font-size: Theme.font-sub; }
        }
    }

    touch := TouchArea { clicked => { root.clicked() } }
}

export component PremiumScrollView inherits Rectangle {
    in property <length> viewport_height;
    out property <length> viewport_y: flick.viewport-y;
    
    clip: true;
    
    flick := Flickable {
        width: parent.width;
        height: parent.height;
        viewport-height: root.viewport_height;
        @children
    }
    
    if (flick.viewport-height > flick.height): Rectangle {
        width: 4px;
        height: max(20px, flick.height * (flick.height / flick.viewport-height));
        x: parent.width - 6px;
        y: -flick.viewport-y * (flick.height / flick.viewport-height);
        background: #bb86fc66;
        border-radius: 2px;
    }
}

export component AppSectionCard inherits Rectangle {
    in property <string> title;
    in property <string> description;
    
    background: Theme.surface;
    border-radius: Theme.radius-large;
    border-width: 1px;
    border-color: Theme.border;
    
    VerticalLayout {
        padding: 20px;
        spacing: 16px;
        
        VerticalLayout {
            spacing: 4px;
            if title != "": Text { text: root.title; color: Theme.text-primary; font-size: Theme.font-header; font-weight: 700; }
            if description != "": Text { text: root.description; color: Theme.text-muted; font-size: Theme.font-sub; wrap: word-wrap; }
        }
        
        Rectangle { height: 1px; background: Theme.border; }
        
        @children
    }
}

export component AppTextField inherits Rectangle {
    in-out property <string> text;
    in property <string> placeholder_text;
    in property <string> label;
    in property <string> helper_text;
    in property <bool> is_error: false;
    
    height: layout.preferred-height;
    
    layout := VerticalLayout {
        spacing: 6px;
        if label != "": Text { text: root.label; color: Theme.text-primary; font-size: Theme.font-body; }
        
        LineEdit {
            text <=> root.text;
            placeholder-text: root.placeholder_text;
            height: 36px;
        }
        
        if helper_text != "": Text { text: root.helper_text; color: is_error ? Theme.danger : Theme.text-muted; font-size: Theme.font-sub; }
    }
}

export component StatusBadge inherits Rectangle {
    in property <string> text;
    in property <bool> is_active: false;
    
    width: 60px;
    height: 22px;
    border-radius: Theme.radius-small;
    background: is_active ? Theme.success-bg : Theme.surface-raised;
    border-width: 1px;
    border-color: is_active ? Theme.success : Theme.border;
    
    Text { 
        text: root.text; 
        color: is_active ? Theme.success : Theme.text-muted; 
        font-size: Theme.font-caption; 
        horizontal-alignment: center; 
        vertical-alignment: center; 
        font-weight: 600; 
    }
}

export component EmptyState inherits VerticalLayout {
    in property <string> title;
    in property <string> subtitle;
    in property <image> icon;
    
    alignment: center;
    spacing: 16px;
    padding: 40px;
    
    Rectangle {
        width: 64px; height: 64px; border-radius: 32px;
        background: Theme.surface-raised;
        Image { source: root.icon; colorize: Theme.text-muted; width: 32px; height: 32px; x: 16px; y: 16px; }
    }
    
    VerticalLayout {
        spacing: 8px;
        alignment: center;
        Text { text: root.title; color: Theme.text-primary; font-size: Theme.font-header; font-weight: 700; horizontal-alignment: center; }
        Text { text: root.subtitle; color: Theme.text-muted; font-size: Theme.font-body; horizontal-alignment: center; wrap: word-wrap; }
    }
    
    @children
}

export component LoadingIndicator inherits Rectangle {
    width: 24px;
    height: 24px;
    
    Rectangle {
        width: 100%; height: 100%;
        border-radius: self.width / 2;
        border-width: 2px;
        border-color: transparent;
        // Slint doesn't have partial border natively easily, so we use a rotating icon or just text if icon is not available
        // For simplicity, we just use a small rotating block or standard Slint trick.
        Text { text: "↻"; color: Theme.secondary; font-size: 20px; horizontal-alignment: center; vertical-alignment: center; 
               transform-rotation: animation-tick() / 1s * 360deg; }
    }
}

export component ModalShell inherits Rectangle {
    in property <string> title;
    in property <bool> is_open: false;
    callback close_clicked();
    
    opacity: root.is_open ? 1 : 0;
    visible: root.opacity > 0;
    animate opacity { duration: 200ms; }
    
    // Backdrop
    TouchArea {
        width: 100%; height: 100%;
        Rectangle { width: 100%; height: 100%; background: #000000aa; }
        clicked => { root.close_clicked() }
    }
    
    // Dialog Box
    Rectangle {
        width: min(parent.width - 40px, 400px);
        height: layout.preferred-height;
        x: (parent.width - self.width) / 2;
        y: root.is_open ? (parent.height - self.height) / 2 : (parent.height - self.height) / 2 + 20px;
        background: Theme.app-bg;
        border-radius: Theme.radius-large;
        border-width: 1px;
        border-color: Theme.border;
        drop-shadow-blur: 20px;
        drop-shadow-color: #000000cc;
        animate y { duration: 200ms; easing: ease-out; }
        
        layout := VerticalLayout {
            padding: 24px;
            spacing: 20px;
            
            HorizontalLayout {
                alignment: space-between;
                Text { text: root.title; color: Theme.text-primary; font-size: Theme.font-header; font-weight: 700; vertical-alignment: center; }
                IconButton { icon: @image-url("back.svg"); tooltip_text: "Close"; clicked => { root.close_clicked() } } // Use back.svg or an X icon. Since X is not an svg we have, we'll use a small button with text 'x' later if needed, but let's just use text for close.
            }
            
            @children
        }
    }
}

export component AppComboBox inherits Rectangle {
    in property <[string]> model;
    in-out property <string> current_value;
    callback selected();
    
    ComboBox {
        model: root.model;
        current-value <=> root.current_value;
        selected => { root.selected() }
    }
}